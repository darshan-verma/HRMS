# Copy to .env and fill in real values. This is the only env file committed to git.
# Required for app: DATABASE_URL, REDIS_URL, JWT_ACCESS_SECRET, JWT_REFRESH_SECRET, ENCRYPTION_MASTER_KEY_HEX

NODE_ENV=development
APP_NAME=enterprise-hrms
NEXTAUTH_URL=http://localhost:3000

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hrms
REDIS_URL=redis://localhost:6379

JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

ENCRYPTION_MASTER_KEY_HEX=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

S3_BUCKET=hrms-private-docs
S3_REGION=ap-south-1
S3_ACCESS_KEY_ID=change_me
S3_SECRET_ACCESS_KEY=change_me

SEED_ORG_NAME=Acme HRMS
SEED_ADMIN_EMAIL=admin@example.com
